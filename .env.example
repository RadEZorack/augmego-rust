BACKEND_BIND_ADDR=0.0.0.0:4000
PUBLIC_BASE_URL=https://dev.augmego.ca
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/augmego
VALKEY_URL=redis://127.0.0.1:6379
WORLD_CACHE_NAMESPACE=local
WORLD_CACHE_TTL_SECS=86400
WORLD_CACHE_REQUIRED=false
BACKEND_STATIC_ROOT=backend/static

COOKIE_SAMESITE=None
COOKIE_SECURE=true
SESSION_COOKIE_NAME=augmego_session
SESSION_COOKIE_TTL_SECS=604800
GAME_BACKEND_AUTH_SECRET=replace-with-a-long-random-secret
GAME_AUTH_TTL_SECS=900

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SCOPE=openid email profile

APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=com.example.api
APPLE_CLIENT_SECRET=
APPLE_PRIVATE_KEY=
APPLE_SCOPE=name email

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

PET_POOL_TARGET=30
PET_GENERATION_MAX_IN_FLIGHT=2
PET_GENERATION_WORKER_INTERVAL_SECS=5
PET_GENERATION_POLL_INTERVAL_SECS=5
PET_GENERATION_MAX_ATTEMPTS=5

MESHY_API_KEY=
MESHY_API_BASE_URL=https://api.meshy.ai
MESHY_TEXT_TO_3D_MODEL=meshy-6
MESHY_TEXT_TO_3D_MODEL_TYPE=standard
MESHY_TEXT_TO_3D_ENABLE_REFINE=true
MESHY_TEXT_TO_3D_REFINE_MODEL=meshy-6
MESHY_TEXT_TO_3D_TARGET_POLYCOUNT=100
MESHY_TEXT_TO_3D_ENABLE_PBR=false
GENERATED_PET_TEXTURE_MAX_DIMENSION=256
GENERATED_PET_TEXTURE_JPEG_QUALITY=75
MESHY_TEXT_TO_3D_TOPOLOGY=triangle

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_AVATAR_IMAGE_MODEL=gpt-image-1.5
GENERATED_AVATAR_CACHE_CONTROL=public, max-age=31536000, immutable
GENERATED_AVATAR_TEXTURE_MAX_DIMENSION=1024
GENERATED_AVATAR_TEXTURE_JPEG_QUALITY=85
AVATAR_GENERATION_IDLE_ACTION_ID=0
AVATAR_GENERATION_DANCE_ACTION_ID=22
AVATAR_GENERATION_WORKER_INTERVAL_SECS=10
AVATAR_GENERATION_POLL_INTERVAL_SECS=10
AVATAR_GENERATION_MAX_ATTEMPTS=3

ASSET_STORAGE_PROVIDER=local
ASSET_STORAGE_ROOT=storage/world-assets
ASSET_STORAGE_NAMESPACE=dev

SPACES_BUCKET=
SPACES_ENDPOINT=
SPACES_CUSTOM_DOMAIN=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_REGION=

# Managed DigitalOcean Valkey connections typically use rediss:// URLs.

# Legacy aliases from the old Next.js stack are also accepted during migration:
# WEB_BASE_URL
# REDIS_URL
# WORLD_STORAGE_PROVIDER
# WORLD_STORAGE_ROOT
# WORLD_STORAGE_NAMESPACE
# DO_SPACES_BUCKET
# DO_SPACES_ENDPOINT
# DO_SPACES_CUSTOM_DOMAIN
# DO_SPACES_KEY
# DO_SPACES_SECRET
# DO_SPACES_REGION
